{
  "name": "money-manager",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "config": "node scripts/set-env.js",
    "build": "npm run config && ng build --configuration production",
    "build:cache-bust": "npm run config && node deploy-cache-bust.js && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false && npx playwright test -c playwright.e2e.config.ts",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:coverage": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:pre-commit": "ng test --watch=false --browsers=ChromeHeadless",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build:with-tests": "npm run test:ci && npm run config && ng build --configuration production",
    "cache-bust": "node deploy-cache-bust.js",
    "deploy": "npm run config && npm run cache-bust && npm run build",
    "postbuild": "cp README.md dist/money-manager/README.md",
    "prepare": "husky",
    "i18n:check": "node scripts/check-i18n.js",
    "i18n:sync": "node scripts/sync-i18n.js"
  },
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^20.0.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@ngrx/effects": "^20.0.0",
    "@ngrx/entity": "^20.0.0",
    "@ngrx/store": "^20.0.0",
    "@ngrx/store-devtools": "^20.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "dayjs": "^1.11.19",
    "firebase": "^12.10.0",
    "ngx-mat-select-search": "^8.0.4",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.58.2",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.10.0",
    "angular-cli-ghpages": "^2.0.1",
    "husky": "^9.1.7",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "tailwindcss": "^3.4.10",
    "typescript": "~5.9.0"
  }
}
